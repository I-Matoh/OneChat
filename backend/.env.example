PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/onechat
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change_me_in_production
# CLIENT_URL: Must be set to your frontend URL for CORS to work
# Local: http://localhost:5173
# Production: https://your-frontend.vercel.app (no trailing slash)
CLIENT_URL=http://localhost:5173

# Supabase Configuration (optional - for JWT verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
